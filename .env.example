# =====================================================
# .env.example — תבנית למשתני סביבה של i24-ratings-forecast
# =====================================================
#
# שימוש:
#   1. עתקי את הקובץ הזה כ-`.env`  (cp .env.example .env)
#   2. מלאי את הערכים שמסומנים ב-REPLACE_ME למטה
#   3. שמרי. הקובץ .env מוגדר ב-.gitignore — לא יעלה ל-GitHub
#
# ⚠️ אל תקבעי את ה-.env לגיט! לעולם!
# =====================================================

# Supabase Project — public values (ok להחזיק בקוד / לעיתון)
SUPABASE_URL=https://bfnmaogcxdgnaxwjdtny.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_7RMhqEoPZs73M1ZSbP0Uww_YLE9Nv76

# Secret — למלא אחרי שמשיגים מ-Supabase → Settings → API Keys → Secret keys
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME

# Direct Postgres connection — להעלאת דאטא מהסקריפט.
# למצוא ב-Supabase → Settings → Database → Connection string → "URI" tab
# החליפי את YOUR_DB_PASSWORD בסיסמה שאיפסת/יצרת.
DATABASE_URL=postgresql://postgres.bfnmaogcxdgnaxwjdtny:YOUR_DB_PASSWORD@aws-1-eu-central-1.pooler.supabase.com:5432/postgres

# =====================================================
# Stripe (אופציונלי — דורש חשבון. ראה STRIPE_SETUP.md)
# =====================================================
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRICE_PRO_MONTHLY=price_REPLACE_ME
